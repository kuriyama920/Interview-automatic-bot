# ===========================================
# Electron アプリ用環境変数
# ===========================================
# このファイルをコピーして .env を作成してください:  cp .env.example .env

# SaaS API エンドポイント（Cloudflare Workers）
# ※ electron-vite の MAIN_VITE_ プレフィックスでビルド時に import.meta.env へ注入されます。
#   プレフィックスが無い名前（例: API_BASE_URL）は反映されないので注意。
# 未設定の場合は本番URL（interview-bot-api...workers.dev）が既定値として使われます。
# ローカル開発で別のエンドポイントへ向ける場合のみ設定してください:
# MAIN_VITE_API_BASE_URL=http://localhost:3000

# カスタムキー使用時のみ（プロキシモードでは不要。通常はWorker側でキーを管理します）
# SONIOX_API_KEY=your_soniox_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# ログレベル (debug | info | warn | error)
LOG_LEVEL=info
