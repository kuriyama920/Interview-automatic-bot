# ===========================================
# Electron アプリ用環境変数
# ===========================================

# Deepgram API
# 取得先: https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OpenAI API
# 取得先: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# オプション: Anthropic Claude API
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ログレベル (debug | info | warn | error)
LOG_LEVEL=info

# アプリ設定
NODE_ENV=development

# SaaS API (Vercel)
# ローカル開発時は http://localhost:3000
# 本番環境では https://your-api.vercel.app
API_BASE_URL=http://localhost:3000

# electron-store 暗号化キー（32文字以上のランダム文字列を生成）
# 生成例: openssl rand -base64 32
ELECTRON_STORE_ENCRYPTION_KEY=your_random_encryption_key_here

# ===========================================
# Vercel API 用環境変数 (apps/api/.env.local)
# ===========================================

# Google OAuth
# 取得先: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT シークレット（64文字以上のランダム文字列を生成）
# 生成例: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here

# Supabase
# 取得先: https://supabase.com/dashboard/project/xxx/settings/api
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe（Phase 7で使用）
# 取得先: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
