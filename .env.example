# ===========================================
# Electron アプリ用環境変数
# ===========================================

# Soniox API (STTプロバイダー)
# 取得先: https://console.soniox.com/
SONIOX_API_KEY=your_soniox_api_key_here

# Deepgram API (廃止予定)
# DEEPGRAM_API_KEY=your_deepgram_api_key_here

# OpenAI API
# 取得先: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# オプション: Anthropic Claude API
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ログレベル (debug | info | warn | error)
LOG_LEVEL=info

# アプリ設定
NODE_ENV=development

# SaaS API (Cloudflare Workers)
# ローカル開発時は http://localhost:3000
# 本番環境では https://interview-bot-api.interviewautomaticbot92.workers.dev
API_BASE_URL=http://localhost:3000

# electron-store 暗号化キー（32文字以上のランダム文字列を生成）
# 生成例: openssl rand -base64 32
ELECTRON_STORE_ENCRYPTION_KEY=your_random_encryption_key_here
