{
  "version": 2,
  "installCommand": "cd apps/api && npm install",
  "framework": null,
  "builds": [
    { "src": "apps/api/api/**/*.ts", "use": "@vercel/node@3.2.29" }
  ],
  "rewrites": [
    { "source": "/api/auth/google", "destination": "/apps/api/api/auth/unified?__route=google" },
    { "source": "/api/auth/callback", "destination": "/apps/api/api/auth/unified?__route=callback" },
    { "source": "/api/auth/session", "destination": "/apps/api/api/auth/unified?__route=session" },
    { "source": "/api/auth/me", "destination": "/apps/api/api/auth/unified?__route=me" },

    { "source": "/api/stripe/checkout", "destination": "/apps/api/api/stripe/billing?__route=checkout" },
    { "source": "/api/stripe/portal", "destination": "/apps/api/api/stripe/billing?__route=portal" },
    { "source": "/api/stripe/webhook", "destination": "/apps/api/api/stripe/webhook" },
    { "source": "/api/stripe/success", "destination": "/apps/api/api/stripe/pages?__route=success" },
    { "source": "/api/stripe/cancel", "destination": "/apps/api/api/stripe/pages?__route=cancel" },

    { "source": "/api/ai/generate", "destination": "/apps/api/api/ai/unified?__route=generate" },
    { "source": "/api/ai/embeddings", "destination": "/apps/api/api/ai/unified?__route=embeddings" },

    { "source": "/api/stt/token", "destination": "/apps/api/api/stt/unified?__route=token" },
    { "source": "/api/stt/usage", "destination": "/apps/api/api/stt/unified?__route=usage" },

    { "source": "/api/documents/search", "destination": "/apps/api/api/documents/search" },
    { "source": "/api/documents/:id", "destination": "/apps/api/api/documents/crud?id=:id" },
    { "source": "/api/documents", "destination": "/apps/api/api/documents/crud" },

    { "source": "/api/questions/generate", "destination": "/apps/api/api/questions/generate" },
    { "source": "/api/questions/:id", "destination": "/apps/api/api/questions/crud?id=:id" },
    { "source": "/api/questions", "destination": "/apps/api/api/questions/crud" },

    { "source": "/api/subscription", "destination": "/apps/api/api/subscription" },
    { "source": "/api/cron/reset-usage", "destination": "/apps/api/api/cron/reset-usage" }
  ]
}
